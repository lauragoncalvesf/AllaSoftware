datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())

  usuarios Usuario[]
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("funcionario")
  empresaId Int
  createdAt DateTime @default(now())

  empresa    Empresa  @relation(fields: [empresaId], references: [id])
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String
  telefone    String?
  email       String?
  status      String   @default("em_dia")
  observacoes String?
  empresaId   Int
  createdAt   DateTime @default(now())

  contasReceber ContaReceber[]
}

model Transacao {
  id        Int      @id @default(autoincrement())
  tipo      String
  valor     Float
  categoria String?
  descricao String?
  formaPagamento String?
  status    String   @default("ativa")
  empresaId Int
  createdAt DateTime @default(now())
}

model ContaReceber {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  empresaId   Int
  descricao   String?
  valorTotal  Float
  valorPago   Float    @default(0)
  status      String   @default("pendente")
  vencimento  DateTime?
  createdAt   DateTime @default(now())

  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  pagamentos  PagamentoContaReceber[]
  vendas Venda[]
}

model PagamentoContaReceber {
  id             Int      @id @default(autoincrement())
  contaReceberId Int
  empresaId      Int
  valor          Float
  formaPagamento String?
  descricao      String?
  createdAt      DateTime @default(now())

  contaReceber   ContaReceber @relation(fields: [contaReceberId], references: [id])
}

model Servico {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  duracao   Int?
  status    String    @default("ativo")
  empresaId Int
  createdAt DateTime  @default(now())
}

model Produto {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String?
  precoVarejo   Float
  precoAtacado  Float?
  estoque       Int?     
  status        String   @default("ativo")
  empresaId     Int
  createdAt     DateTime @default(now())
}

model Venda {
  id             Int         @id @default(autoincrement())
  clienteId      Int?
  empresaId      Int
  contaReceberId Int?
  tipoPreco      String      @default("varejo")
  desconto       Float       @default(0)
  totalBruto     Float
  totalFinal     Float
  status         String      @default("fechada")
  createdAt      DateTime    @default(now())

  itens          ItemVenda[]
  contaReceber   ContaReceber? @relation(fields: [contaReceberId], references: [id])
}

model ItemVenda {
  id            Int      @id @default(autoincrement())
  vendaId       Int
  tipoItem      String
  referenciaId  Int
  nomeItem      String
  quantidade    Int      @default(1)
  precoUnitario Float
  subtotal      Float
  createdAt     DateTime @default(now())

  venda         Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  empresaId Int
  usuarioId Int?
  acao      String
  entidade  String
  descricao String?
  dados     String?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([empresaId])
  @@index([usuarioId])
  @@index([timestamp])
}