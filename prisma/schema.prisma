datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Empresa {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())

  cpfCnpj     String?
  celular    String?
  cep         String?
  rua         String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  usuarios Usuario[]
  comissoes Comissao[]
  whatsappConfig EmpresaWhatsApp?
  mensagensWhatsApp MensagemWhatsApp[]
}

model Usuario {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String   @unique
  senha       String
  role        String   @default("funcionario")
  cargo       String?
  status      String   @default("ativo")
  permissoes  Json?
  empresaId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  tipoEquipe                 String   @default("profissional")
  profissional               Boolean  @default(true)
  preSelecionarAgendamento   Boolean  @default(true)

  comissaoPercentualPadrao   Float    @default(0)

  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  agendamentosProfissional Agendamento[] @relation("ProfissionalAgendamentos")
  vendasComoVendedor       Venda[] @relation("VendasVendedor")
  comissoes                Comissao[]
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String
  telefone    String?
  email       String?
  status      String   @default("em_dia")
  observacoes String?
  whatsappOptIn Boolean @default(true)
  empresaId   Int
  createdAt   DateTime @default(now())

  contasReceber ContaReceber[]
  agendamentos Agendamento[]
  vendas Venda[]
  mensagensWhatsApp MensagemWhatsApp[]
}

model Transacao {
  id        Int      @id @default(autoincrement())
  tipo      String
  valor     Float
  categoria String?
  descricao String?
  formaPagamento String?
  status    String   @default("ativa")
  empresaId Int
  createdAt DateTime @default(now())

  comissoes Comissao[]
}

model ContaReceber {
  id          Int      @id @default(autoincrement())
  clienteId   Int
  empresaId   Int
  descricao   String?
  valorTotal  Float
  valorPago   Float    @default(0)
  status      String   @default("pendente")
  vencimento  DateTime?
  createdAt   DateTime @default(now())

  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  pagamentos  PagamentoContaReceber[]
  vendas Venda[]
}

model PagamentoContaReceber {
  id             Int      @id @default(autoincrement())
  contaReceberId Int
  empresaId      Int
  valor          Float
  formaPagamento String?
  descricao      String?
  createdAt      DateTime @default(now())

  contaReceber   ContaReceber @relation(fields: [contaReceberId], references: [id])
}

model Servico {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String?
  preco     Float
  duracao   Int?
  status    String    @default("ativo")
  empresaId Int
  createdAt DateTime  @default(now())

  comissaoPercentual Float?

  agendamentos Agendamento[]
}

model Produto {
  id            Int      @id @default(autoincrement())
  nome          String
  descricao     String?
  precoVarejo   Float
  precoAtacado  Float?
  precoCusto    Float?
  estoque       Int?
  status        String   @default("ativo")
  empresaId     Int
  createdAt     DateTime @default(now())

  comissaoPercentual Float?
}

model Venda {
  id             Int         @id @default(autoincrement())
  clienteId      Int?
  empresaId      Int
  contaReceberId Int?
  vendedorId     Int?

  tipoPreco      String      @default("varejo")
  desconto       Float       @default(0)
  totalBruto     Float
  totalFinal     Float
  status         String      @default("fechada")
  createdAt      DateTime    @default(now())

  itens          ItemVenda[]
  agendamento Agendamento?
  comissoes      Comissao[]
  cliente        Cliente? @relation(fields: [clienteId], references: [id])
  contaReceber   ContaReceber? @relation(fields: [contaReceberId], references: [id])
  vendedor       Usuario? @relation("VendasVendedor", fields: [vendedorId], references: [id])

  @@index([clienteId])
  @@index([vendedorId])
  @@index([empresaId])
  @@index([createdAt])
}

model ItemVenda {
  id            Int      @id @default(autoincrement())
  vendaId       Int
  tipoItem      String
  referenciaId  Int
  nomeItem      String
  quantidade    Int      @default(1)
  precoUnitario Float
  custoUnitario Float?
  custoTotal    Float?
  lucroBruto    Float?
  subtotal      Float
  createdAt     DateTime @default(now())

  venda         Venda    @relation(fields: [vendaId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  empresaId Int
  usuarioId Int?
  acao      String
  entidade  String
  descricao String?
  dados     String?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  @@index([empresaId])
  @@index([usuarioId])
  @@index([timestamp])
}

model Agendamento {
  id             Int      @id @default(autoincrement())
  clienteId      Int?
  servicoId      Int?
  profissionalId Int?
  empresaId      Int
  vendaId        Int?     @unique

  titulo         String
  descricao      String?
  dataHora       DateTime
  status         String   @default("agendado")
  valorServico   Float?
  observacoes    String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt
  concluidoEm    DateTime?

  cliente        Cliente? @relation(fields: [clienteId], references: [id])
  servico        Servico? @relation(fields: [servicoId], references: [id])
  profissional   Usuario? @relation("ProfissionalAgendamentos", fields: [profissionalId], references: [id])
  venda          Venda?   @relation(fields: [vendaId], references: [id])
  comissoes      Comissao[]
  mensagensWhatsApp MensagemWhatsApp[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([servicoId])
  @@index([profissionalId])
  @@index([status])
  @@index([dataHora])
}

model EmpresaWhatsApp {
  id                   Int      @id @default(autoincrement())
  empresaId            Int      @unique
  ativo                Boolean  @default(false)
  numero               String?
  nomeExibicao         String?
  businessId           String?
  wabaId               String?
  phoneNumberId        String
  accessTokenEncrypted String
  templateConfirmacao  String   @default("agendamento_confirmado")
  templateLembrete24h  String   @default("lembrete_agendamento_24h")
  idioma               String   @default("pt_BR")
  status               String   @default("manual")
  ultimoErro           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  empresa              Empresa  @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model MensagemWhatsApp {
  id                Int      @id @default(autoincrement())
  empresaId         Int
  agendamentoId     Int?
  clienteId         Int?
  tipo              String
  canal             String   @default("whatsapp")
  destino           String
  templateName      String?
  payload           Json?
  status            String   @default("pendente")
  providerMessageId String?
  erro              String?
  scheduledFor      DateTime?
  enviadoEm         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  empresa           Empresa @relation(fields: [empresaId], references: [id])
  agendamento       Agendamento? @relation(fields: [agendamentoId], references: [id])
  cliente           Cliente? @relation(fields: [clienteId], references: [id])

  @@index([empresaId])
  @@index([agendamentoId])
  @@index([clienteId])
  @@index([status])
  @@index([scheduledFor])
}

model Comissao {
  id             Int       @id @default(autoincrement())
  empresaId      Int
  usuarioId      Int
  vendaId        Int?
  agendamentoId  Int?
  transacaoId    Int?

  tipo           String
  descricao      String?
  valorBase      Float
  percentual     Float
  valorComissao  Float
  status         String    @default("pendente")
  dataPagamento  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  empresa        Empresa     @relation(fields: [empresaId], references: [id])
  usuario        Usuario     @relation(fields: [usuarioId], references: [id])
  venda          Venda?      @relation(fields: [vendaId], references: [id])
  agendamento    Agendamento? @relation(fields: [agendamentoId], references: [id])
  transacao      Transacao?  @relation(fields: [transacaoId], references: [id])

  @@index([empresaId])
  @@index([usuarioId])
  @@index([vendaId])
  @@index([agendamentoId])
  @@index([status])
  @@index([createdAt])
}
