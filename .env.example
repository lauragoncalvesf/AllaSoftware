# 🔧 VARIÁVEIS DE AMBIENTE

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sistemasaas"

# JWT
JWT_SECRET="sua_chave_secreta_super_segura_aqui_min_32_caracteres"
JWT_REFRESH_SECRET="sua_chave_refresh_super_segura_aqui_min_32_caracteres"
JWT_EXPIRE="never"

# Server
NODE_ENV="development"
PORT=3000

# CORS
FRONTEND_URL="http://localhost:5173"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logs
LOG_LEVEL="info"

# Email (Gmail ou outro SMTP)
EMAIL_USER="seu_email@gmail.com"
EMAIL_PASSWORD="sua_senha_app_do_gmail"

